<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Hermes Engine Visualizer</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0c0c0d;
            --surface: #161618;
            --surface-2: #1e1e22;
            --surface-3: #26262b;
            --border: #2a2a2f;
            --border-accent: #3b82f6;
            --text: #f0f0f5;
            --text-muted: #8b8b9e;
            --text-dim: #55556a;
            --accent: #3b82f6;
            --accent-glow: rgba(59, 130, 246, 0.15);
            --green: #22c55e;
            --green-dim: rgba(34, 197, 94, 0.12);
            --red: #ef4444;
            --red-dim: rgba(239, 68, 68, 0.12);
            --yellow: #eab308;
            --yellow-dim: rgba(234, 179, 8, 0.1);
            --radius: 12px;
            --mono: 'JetBrains Mono', monospace;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Header ── */
        .header {
            padding: 32px 40px 24px;
            border-bottom: 1px solid var(--border);
        }
        .header h1 {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 4px;
        }
        .header p { font-size: 13px; color: var(--text-muted); }

        /* ── Layout ── */
        .app { max-width: 1100px; margin: 0 auto; padding: 24px 40px 60px; }

        /* ── Input Card ── */
        .input-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            margin-bottom: 24px;
        }
        .input-row {
            display: flex;
            gap: 12px;
            align-items: flex-end;
        }
        .input-group { display: flex; flex-direction: column; }
        .input-group.expand { flex: 1; }
        .input-group label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--text-muted);
            margin-bottom: 6px;
        }
        select, input[type="text"] {
            padding: 12px 14px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            background: var(--surface-2);
            color: var(--text);
            font-size: 14px;
            font-family: var(--mono);
            outline: none;
            transition: border-color 0.2s;
        }
        select { cursor: pointer; min-width: 160px; }
        select:focus, input:focus { border-color: var(--accent); }
        .run-btn {
            padding: 12px 28px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .run-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3); }

        /* ── Slider Controls ── */
        .slider-controls {
            display: none;
            align-items: center;
            justify-content: space-between;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 14px 20px;
            margin-bottom: 20px;
        }
        .slider-controls.active { display: flex; }
        .slider-nav {
            display: flex;
            gap: 8px;
        }
        .slider-btn {
            padding: 8px 20px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            background: var(--surface-2);
            color: var(--text);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .slider-btn:hover:not(:disabled) {
            border-color: var(--accent);
            background: var(--accent-glow);
        }
        .slider-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }
        .slider-dots {
            display: flex;
            gap: 6px;
            align-items: center;
        }
        .slider-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--surface-3);
            border: 1.5px solid var(--border);
            transition: all 0.3s;
            cursor: pointer;
        }
        .slider-dot.completed {
            background: var(--green);
            border-color: var(--green);
        }
        .slider-dot.current {
            background: var(--accent);
            border-color: var(--accent);
            box-shadow: 0 0 8px rgba(59, 130, 246, 0.4);
            transform: scale(1.2);
        }
        .slider-dot.failed {
            background: var(--red);
            border-color: var(--red);
        }
        .slider-indicator {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
            font-family: var(--mono);
        }

        /* ── Step Card ── */
        .step-slide {
            display: none;
            animation: fadeSlide 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .step-slide.active { display: block; }

        @keyframes fadeSlide {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .step {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }
        .step-header {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 16px 20px;
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
        }
        .step-num {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--accent-glow);
            color: var(--accent);
            font-size: 12px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .step-title { font-size: 14px; font-weight: 700; letter-spacing: 0.2px; }
        .step-badge {
            margin-left: auto;
            font-size: 11px;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .badge-pass { background: var(--green-dim); color: var(--green); }
        .badge-fail { background: var(--red-dim); color: var(--red); }
        .badge-warn { background: var(--yellow-dim); color: var(--yellow); }
        .badge-skip { background: var(--surface-3); color: var(--text-dim); }

        .step-body { padding: 20px; }
        .step-body p { font-size: 13px; color: var(--text-muted); line-height: 1.7; }

        /* ── Code / Mono blocks ── */
        .mono {
            font-family: var(--mono);
            font-size: 12.5px;
            background: var(--surface-3);
            padding: 14px 16px;
            border-radius: 8px;
            line-height: 1.8;
            overflow-x: auto;
            color: var(--text);
            word-break: break-all;
        }
        .mono .filtered {
            text-decoration: line-through;
            color: var(--red);
            opacity: 0.55;
        }
        .mono .kept { color: var(--green); font-weight: 600; }

        /* ── Score Bars ── */
        .scores-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 12px;
            margin-top: 14px;
        }
        .score-item {
            background: var(--surface-3);
            border-radius: 10px;
            padding: 16px;
        }
        .score-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-dim);
            margin-bottom: 8px;
        }
        .score-value {
            font-family: var(--mono);
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 8px;
        }
        .score-bar {
            height: 6px;
            background: var(--surface);
            border-radius: 3px;
            overflow: hidden;
        }
        .score-bar-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .score-detail {
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 6px;
            font-family: var(--mono);
        }

        /* ── Final Result / Comparison ── */
        .final-result {
            background: var(--surface-2);
            border-radius: 10px;
            padding: 20px;
            margin-top: 14px;
        }
        .final-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
        }
        .final-row:last-child { border-bottom: none; }
        .final-label { font-size: 12px; color: var(--text-muted); font-weight: 600; }
        .final-value {
            font-family: var(--mono);
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            text-align: right;
            max-width: 65%;
            word-break: break-all;
        }

        .comparison {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 12px;
        }
        .comp-box {
            background: var(--surface-3);
            border-radius: 8px;
            padding: 14px 16px;
        }
        .comp-box .comp-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--text-dim);
            margin-bottom: 8px;
        }
        .comp-box .comp-value {
            font-family: var(--mono);
            font-size: 12.5px;
            color: var(--text);
            line-height: 1.6;
            word-break: break-all;
        }

        /* ── Weight Breakdown ── */
        .weight-row {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            font-size: 13px;
        }
        .weight-row:last-child { border-bottom: none; }
        .weight-name { flex: 1; color: var(--text-muted); font-weight: 500; }
        .weight-score { font-family: var(--mono); font-weight: 700; width: 60px; text-align: right; }
        .weight-mult { font-family: var(--mono); color: var(--text-dim); font-size: 12px; width: 40px; text-align: center; }
        .weight-result { font-family: var(--mono); font-weight: 700; width: 70px; text-align: right; color: var(--accent); }

        .empty-state {
            text-align: center;
            padding: 100px 20px;
            color: var(--text-dim);
        }
        .empty-state p { font-size: 14px; margin-top: 12px; }

        @media (max-width: 768px) {
            .app { padding: 16px; }
            .header { padding: 20px 16px; }
            .input-row { flex-direction: column; }
            .scores-grid { grid-template-columns: 1fr; }
            .comparison { grid-template-columns: 1fr; }
        }
    </style>
</head>

