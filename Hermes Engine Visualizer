        // ══════════════════════════════════════════════════════════════
        // SIMILARITY HELPERS
        // ══════════════════════════════════════════════════════════════
        function levenshtein(a, b) {
            const m = a.length, n = b.length;
            const dp = Array.from({ length: m + 1 }, () => Array(n + 1).fill(0));
            for (let i = 0; i <= m; i++) dp[i][0] = i;
            for (let j = 0; j <= n; j++) dp[0][j] = j;
            for (let i = 1; i <= m; i++) {
                for (let j = 1; j <= n; j++) {
                    dp[i][j] = a[i - 1] === b[j - 1]
                        ? dp[i - 1][j - 1]
                        : 1 + Math.min(dp[i - 1][j], dp[i][j - 1], dp[i - 1][j - 1]);
                }
            }
            return dp[m][n];
        }

        function longestCommonSubstring(a, b) {
            const m = a.length, n = b.length;
            let max = 0;
            const dp = Array.from({ length: m + 1 }, () => Array(n + 1).fill(0));
            for (let i = 1; i <= m; i++) {
                for (let j = 1; j <= n; j++) {
                    if (a[i - 1] === b[j - 1]) {
                        dp[i][j] = dp[i - 1][j - 1] + 1;
                        if (dp[i][j] > max) max = dp[i][j];
                    }
                }
            }
            return max;
        }

        function wordOverlap(a, b) {
            const wordsA = new Set(a.split(/[\s_\-\/,.]+/).filter(w => w.length > 0));
            const wordsB = new Set(b.split(/[\s_\-\/,.]+/).filter(w => w.length > 0));
            let common = 0;
            wordsA.forEach(w => { if (wordsB.has(w)) common++; });
            const union = new Set([...wordsA, ...wordsB]).size;
            return union === 0 ? 0 : common / union;
        }

        const SIMILARITY_THRESHOLD = 0.40;

        // ══════════════════════════════════════════════════════════════
        // CLEANER WITH DETAILED TRACKING
        // ══════════════════════════════════════════════════════════════
        function cleanBatchInputDetailed(raw) {
            let s = raw;
            const removals = [];

            // 1. .dat file references
            const datMatches = s.match(/[\w\-]*\.dat/gi);
            if (datMatches) datMatches.forEach(m => removals.push({ text: m, reason: '.dat file reference' }));
            s = s.replace(/[\w\-]*\.dat/gi, '');

            // 2. "for" prefix/suffix behavior (keep only what's after "for")
            const forMatch = s.match(/\bfor\s+(.+)$/i);
            if (forMatch) {
                const removedPrefix = s.substring(0, s.indexOf(forMatch[0]));
                if (removedPrefix.trim()) removals.push({ text: removedPrefix.trim(), reason: 'Prefix before "for" keyword' });
                s = forMatch[1];
            }

            // 3. Date patterns (including underscore handling)
            const datePatterns = [
                { re: /_?\d{1,2}\/\d{1,2}\/\d{2,4}_?/g, reason: 'Date (dd/mm/yyyy)' },
                { re: /_?\d{4}[\-\/]\d{2}[\-\/]\d{2}_?/g, reason: 'Date (yyyy-mm-dd)' },
                { re: /_?\d{14}_?/g, reason: 'Timestamp (14 digits)' },
                { re: /_?\d{8}_?/g, reason: 'Date (8 digits)' },
            ];
            datePatterns.forEach(({ re, reason }) => {
                const m = s.match(re);
                if (m) {
                    m.forEach(t => {
                        if (t.trim()) removals.push({ text: t, reason });
                    });
                }
                s = s.replace(re, ' ');
            });

            // 4. Time patterns (at HH:MM, HH:MM AM/PM)
            const timePatterns = [
                { re: /\bat\s+\d{1,2}:\d{2}\s*[APap][Mm]?\b/gi, reason: 'Time pattern (at HH:MM AM/PM)' },
                { re: /\bat\s+\d{1,2}:\d{2}\b/gi, reason: 'Time pattern (at HH:MM)' },
                { re: /\b\d{1,2}:\d{2}\s*[APap][Mm]\b/gi, reason: 'Time pattern (HH:MM AM/PM)' },
                { re: /\b\d{1,2}:\d{2}\b/g, reason: 'Time pattern (HH:MM)' },
            ];
            timePatterns.forEach(({ re, reason }) => {
                const m = s.match(re);
                if (m) {
                    m.forEach(t => {
                        if (t.trim()) removals.push({ text: t, reason });
                    });
                }
                s = s.replace(re, ' ');
            });

            // 5. Long numeric sequences (6+ digits)
            const numRe = /\b\d{6,}\b/g;
            const nm = s.match(numRe);
            if (nm) nm.forEach(t => removals.push({ text: t, reason: 'Numeric sequence (6+ digits)' }));
            s = s.replace(numRe, ' ');

            // 6. Connectors (on/with at the end)
            const connectorRe = /\b(on|with)\s+$/gi;
            const cm = s.match(connectorRe);
            if (cm) cm.forEach(t => removals.push({ text: t, reason: 'Trailing connector' }));
            s = s.replace(connectorRe, ' ');

            // 7. Collapse whitespace and trim
            s = s.replace(/[\s_]+/g, ' ').trim();

            return { cleaned: s, removals };
        }

        // ══════════════════════════════════════════════════════════════
        // VISUALIZATION HELPERS
        // ══════════════════════════════════════════════════════════════
        function buildFilteredHTML(raw, removals) {
            if (removals.length === 0) return `<span class="kept">${esc(raw)}</span>`;

            const ranges = [];
            removals.forEach(r => {
                const idx = raw.indexOf(r.text);
                if (idx !== -1) ranges.push({ start: idx, end: idx + r.text.length, reason: r.reason });
            });
            ranges.sort((a, b) => a.start - b.start);

            const merged = [];
            ranges.forEach(r => {
                if (merged.length && r.start <= merged[merged.length - 1].end) {
                    merged[merged.length - 1].end = Math.max(merged[merged.length - 1].end, r.end);
                } else {
                    merged.push({ ...r });
                }
            });

            let html = '', pos = 0;
            merged.forEach(r => {
                if (pos < r.start) html += `<span class="kept">${esc(raw.substring(pos, r.start))}</span>`;
                html += `<span class="filtered" title="${esc(r.reason)}">${esc(raw.substring(r.start, r.end))}</span>`;
                pos = r.end;
            });
            if (pos < raw.length) html += `<span class="kept">${esc(raw.substring(pos))}</span>`;
            return html;
        }

        function esc(s) {
            return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function scoreColor(score) {
            if (score >= 0.7) return 'var(--green)';
            if (score >= 0.4) return 'var(--yellow)';
            return 'var(--red)';
        }

        function pct(n) { return (n * 100).toFixed(1) + '%'; }

