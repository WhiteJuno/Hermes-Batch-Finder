                     <div class="final-result" style="margin-top: 14px;">
                        <div class="final-row"><span class="final-label">Match Type</span><span class="final-value">Exact (cleaned input)</span></div>
                        <div class="final-row"><span class="final-label">Batch</span><span class="final-value">${esc(exactClean[1])}</span></div>
                        <div class="final-row"><span class="final-label">Decision</span><span class="final-value" style="color: var(--green)">${esc(exactClean[2] || '—')}</span></div>
                     </div>`));
                slideMeta.push({ status: 'pass' });
                controls.classList.add('active');
                renderSlider();
                return;
            }
            slides.push(makeStep(5, 'Exact Match — Cleaned Input', 'badge-fail', 'NO MATCH',
                `<p>No exact match for cleaned input. Proceeding to fuzzy similarity analysis.</p>
                 <div class="comparison" style="margin-top: 12px;">
                    <div class="comp-box">
                        <div class="comp-label">Cleaned Input Searched</div>
                        <div class="comp-value">${esc(cleaned)}</div>
                    </div>
                    <div class="comp-box">
                        <div class="comp-label">Status</div>
                        <div class="comp-value" style="color: var(--yellow)">0 / ${clientRows.length} entries matched</div>
                    </div>
                 </div>`));
            slideMeta.push({ status: 'fail' });

            // ─── STEP 6: Similarity Analysis ───
            const a = cleaned.toLowerCase();
            let bestScore = -1, bestRow = null;
            const allScores = [];

            clientRows.forEach(row => {
                if (!row[1] || row[1].trim() === "") return;
                const b = row[1].toLowerCase();
                const maxLen = Math.max(a.length, b.length) || 1;
                const levDist = levenshtein(a, b);
                const levScore = 1 - (levDist / maxLen);
                const lcsLen = longestCommonSubstring(a, b);
                const lcsScore = lcsLen / maxLen;
                const wScore = wordOverlap(a, b);
                const finalScore = (levScore * 0.30) + (lcsScore * 0.40) + (wScore * 0.30);
                allScores.push({ batch: row[1], decision: row[2], levScore, lcsScore, wScore, finalScore, levDist, lcsLen });
                if (finalScore > bestScore) { bestScore = finalScore; bestRow = row; }
            });

            allScores.sort((a, b) => b.finalScore - a.finalScore);
            const top = allScores[0];
            const passThreshold = bestScore >= SIMILARITY_THRESHOLD;

            const similarityHTML = top ? `
                <div class="comparison">
                    <div class="comp-box">
                        <div class="comp-label">Input (Cleaned)</div>
                        <div class="comp-value">${esc(cleaned)}</div>
                    </div>
                    <div class="comp-box">
                        <div class="comp-label">Best Candidate</div>
                        <div class="comp-value">${esc(top.batch)}</div>
                    </div>
                </div>
                <div class="scores-grid">
                    <div class="score-item">
                        <div class="score-label">Levenshtein</div>
                        <div class="score-value" style="color: ${scoreColor(top.levScore)}">${pct(top.levScore)}</div>
                        <div class="score-bar"><div class="score-bar-fill" style="width:${pct(top.levScore)};background:${scoreColor(top.levScore)}"></div></div>
                        <div class="score-detail">Distance: ${top.levDist} edits // x0.30</div>
                    </div>
                    <div class="score-item">
                        <div class="score-label">Longest Common Substr</div>
                        <div class="score-value" style="color: ${scoreColor(top.lcsScore)}">${pct(top.lcsScore)}</div>
                        <div class="score-bar"><div class="score-bar-fill" style="width:${pct(top.lcsScore)};background:${scoreColor(top.lcsScore)}"></div></div>
                        <div class="score-detail">LCS: ${top.lcsLen} chars // x0.40</div>
                    </div>
                    <div class="score-item">
                        <div class="score-label">Word Overlap (Jaccard)</div>
                        <div class="score-value" style="color: ${scoreColor(top.wScore)}">${pct(top.wScore)}</div>
                        <div class="score-bar"><div class="score-bar-fill" style="width:${pct(top.wScore)};background:${scoreColor(top.wScore)}"></div></div>
                        <div class="score-detail">Token match // x0.30</div>
                    </div>
                </div>

                <div style="margin-top: 16px; padding: 16px; background: var(--surface-3); border-radius: 10px;">
                    <p style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-dim); margin-bottom: 10px;">Weighted Breakdown</p>
                    <div class="weight-row">
                        <span class="weight-name">Levenshtein</span>
                        <span class="weight-score">${pct(top.levScore)}</span>
                        <span class="weight-mult">x 0.30</span>
                        <span class="weight-result">= ${(top.levScore * 0.30).toFixed(4)}</span>
                    </div>
                    <div class="weight-row">
                        <span class="weight-name">LCS Ratio</span>
                        <span class="weight-score">${pct(top.lcsScore)}</span>
                        <span class="weight-mult">x 0.40</span>
                        <span class="weight-result">= ${(top.lcsScore * 0.40).toFixed(4)}</span>
                    </div>
                    <div class="weight-row">
                        <span class="weight-name">Word Overlap</span>
                        <span class="weight-score">${pct(top.wScore)}</span>
                        <span class="weight-mult">x 0.30</span>
                        <span class="weight-result">= ${(top.wScore * 0.30).toFixed(4)}</span>
                    </div>
                    <div class="weight-row" style="border-top: 2px solid var(--border); padding-top: 12px; margin-top: 4px;">
                        <span class="weight-name" style="font-weight: 800; color: var(--text);">Final Score</span>
                        <span class="weight-score"></span>
                        <span class="weight-mult"></span>
                        <span class="weight-result" style="font-size: 16px; color: ${scoreColor(top.finalScore)}">${pct(top.finalScore)}</span>
                    </div>
                </div>

                <div style="margin-top: 16px;">
                    <p style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-dim); margin-bottom: 10px;">Top 5 Candidates</p>
                    ${allScores.slice(0, 5).map((s, i) => `
                        <div style="display: flex; align-items: center; gap: 10px; padding: 10px 12px; margin-bottom: 4px; background: ${i === 0 ? 'var(--accent-glow)' : 'transparent'}; border-radius: 6px; border: 1px solid ${i === 0 ? 'var(--border-accent)' : 'var(--border)'};">
                            <span style="font-family: var(--mono); font-size: 12px; font-weight: 800; color: ${i === 0 ? 'var(--accent)' : 'var(--text-dim)'}; width: 24px;">#${i + 1}</span>
                            <span style="flex: 1; font-family: var(--mono); font-size: 11px; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${esc(s.batch)}</span>
                            <span style="font-family: var(--mono); font-size: 13px; font-weight: 700; color: ${scoreColor(s.finalScore)}">${pct(s.finalScore)}</span>
                        </div>
                    `).join('')}
                </div>
            ` : '<p>No candidates found in database.</p>';

            slides.push(makeStep(6, 'Fuzzy Similarity Analysis', passThreshold ? 'badge-pass' : 'badge-warn', passThreshold ? 'ABOVE THRESHOLD' : 'BELOW THRESHOLD', similarityHTML));
            slideMeta.push({ status: passThreshold ? 'pass' : 'fail' });

            // ─── STEP 7: Threshold Gate ───
            slides.push(makeStep(7, `Threshold Gate — Minimum ${pct(SIMILARITY_THRESHOLD)}`, passThreshold ? 'badge-pass' : 'badge-fail', passThreshold ? 'PASS' : 'REJECTED',
                `<div style="display: flex; align-items: center; gap: 20px;">
                    <div style="font-family: var(--mono); font-size: 36px; font-weight: 800; color: ${scoreColor(bestScore)}">${pct(bestScore)}</div>
                    <div>
                        <p style="font-weight: 700; color: ${passThreshold ? 'var(--green)' : 'var(--red)'}; font-size: 15px;">
                            ${passThreshold ? 'Score exceeds threshold' : 'Score below threshold'}
                        </p>
                        <p style="font-size: 12px; color: var(--text-dim); margin-top: 4px;">
                            ${pct(bestScore)} ${passThreshold ? '>=' : '<'} ${pct(SIMILARITY_THRESHOLD)} required minimum
                        </p>
                    </div>
                </div>`));
            slideMeta.push({ status: passThreshold ? 'pass' : 'fail' });

            // ─── STEP 8: Final Verdict ───
            if (passThreshold && bestRow) {
                slides.push(makeStep('R', 'Final Verdict', 'badge-pass', 'MATCH FOUND',
                    `<p style="font-size: 15px; color: var(--green); font-weight: 700;">Match accepted.</p>
                     <div class="final-result" style="margin-top: 14px;">
                        <div class="final-row"><span class="final-label">Matched Batch</span><span class="final-value">${esc(bestRow[1])}</span></div>
                        <div class="final-row"><span class="final-label">Decision (Pending / Refer to Compliance)</span><span class="final-value" style="color: var(--green)">${esc(bestRow[2] || '—')}</span></div>
                        <div class="final-row"><span class="final-label">Similarity Score</span><span class="final-value" style="color: ${scoreColor(bestScore)}">${pct(bestScore)}</span></div>
                        <div class="final-row"><span class="final-label">Match Type</span><span class="final-value">Fuzzy (best candidate)</span></div>
                     </div>`));
                slideMeta.push({ status: 'pass' });
            } else {
                slides.push(makeStep('R', 'Final Verdict', 'badge-fail', 'NO MATCH',
                    `<p style="font-size: 15px; color: var(--red); font-weight: 700;">This batch does not appear to be in the Hermes database.</p>
                     <p style="font-size: 13px; color: var(--text-muted); margin-top: 8px;">Please contact the Hermes Support.</p>`));
                slideMeta.push({ status: 'fail' });
            }

            controls.classList.add('active');
            renderSlider();
        }
    </script>
</body>

</html>
